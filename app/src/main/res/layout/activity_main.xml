<?xml version="1.0" encoding="utf-8"?>
<!--
    שיעור 6: Event Handling
    =======================
    ה-layout הזה כבר מוכן עבורך!
    כל ה-Views כאן עם ה-IDs הנכונים.
    המשימה שלך: השלם את הקוד ב-MainActivity.java

    Views שזמינים:
      - editTextName     (EditText)  — שדה להזנת שם
      - btnGreet         (Button)    — כפתור "ברוך הבא"
      - btnClear         (Button)    — כפתור "נקה"
      - textViewResult   (TextView)  — תצוגת התוצאה
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="top"
    tools:context=".MainActivity">

    <!-- כותרת האפליקציה -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:textColor="@color/colorPrimary"/>

    <!-- תת-כותרת -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_subtitle"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:textColor="@color/colorHint"/>

    <!-- שדה הזנת שם -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:imeOptions="actionDone"
            android:maxLines="1"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- שורת כפתורים -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnGreet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_greet"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_clear"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

    <!-- קו הפרדה -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginBottom="24dp"/>

    <!-- תצוגת תוצאה -->
    <TextView
        android:id="@+id/textViewResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:gravity="center"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:lineSpacingMultiplier="1.3"
        tools:text="שלום, יונתן! ברוך הבא לאפליקציה!"/>

</LinearLayout>
